{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["tool", "formalism", "result", "timestamp"],
  "properties": {
    "tool": {
      "type": "string"
    },
    "formalism": {
      "type": "string",
      "enum": ["tla", "alloy", "prism", "trace", "redaction", "uppaal"]
    },
    "result": {
      "type": "string",
      "enum": ["pass", "fail", "warn", "inconclusive"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object"
    },
    "check_id": {
      "type": "string"
    },
    "surface": {
      "type": "string"
    },
    "property": {
      "type": "string"
    },
    "runtime_ms": {
      "type": "integer",
      "minimum": 0
    },
    "summary": {
      "type": "string"
    },
    "triage_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "observation_window": {
      "type": "object"
    },
    "requirement_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z]"
      },
      "default": []
    }
  },
  "additionalProperties": false
}
