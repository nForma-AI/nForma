.planning/formal/petri/quorum-petri-net.svg

# XState runtime artifacts (state dumps, snapshots)
states/

# Secret scanning report artifacts (local only)
.gitleaks-report.json
.trufflehog-report.json

# Alloy solver output directories (receipt.json, solution-*.md)
.planning/formal/alloy/*/

# Solve session summaries (local diagnostic artifacts, pruned to 20)
.planning/formal/solve-sessions/

# Generated formal-test-sync stubs (regenerated on demand)
