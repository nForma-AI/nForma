      "cli": "/opt/homebrew/bin/codex",
      "args_template": ["exec", "{prompt}"],
      "helpArgs": ["--help"],
      "extraTools": [
        {
          "name": "review",
          "description": "Run a code review against the current repository using Codex CLI",
          "args_template": ["review", "{prompt}"]
        }
      ],
      "timeout_ms": 300000,
      "quorum_timeout_ms": 30000,
      "env": {}
    },
    {
      "name": "gemini-1",
      "type": "subprocess",
      "description": "Query Gemini CLI agent non-interactively (slot 1)",
      "mainTool": "gemini",
      "model": "gemini-3-pro-preview",
      "health_check_args": ["--version"],
      "display_provider": "Google",
      "cli": "/opt/homebrew/bin/gemini",
      "args_template": ["-m", "gemini-3-pro-preview", "-p", "{prompt}"],
      "helpArgs": ["--help"],
      "extraTools": [],
      "timeout_ms": 300000,
      "quorum_timeout_ms": 30000,
      "env": {}
    },
    {
      "name": "gemini-2",
      "type": "subprocess",
      "description": "Query Gemini CLI agent non-interactively (slot 2)",
      "mainTool": "gemini",
      "model": "gemini-3-pro-preview",
      "health_check_args": ["--version"],
      "display_provider": "Google",
