{
  "providers": [
    {
      "name": "codex-1",
      "type": "subprocess",
      "description": "Execute Codex CLI agent non-interactively (slot 1)",
      "mainTool": "codex",
      "model": "gpt-5.3-codex",
      "model_detect": {
        "file": "~/.codex/config.toml",
        "pattern": "^model = \"([^\"]+)\""
      },
      "health_check_args": ["--version"],
      "display_provider": "OpenAI",
      "cli": "/opt/homebrew/bin/codex",
      "args_template": ["exec", "{prompt}"],
      "helpArgs": ["--help"],
      "extraTools": [
        {
          "name": "review",
          "description": "Run a code review against the current repository using Codex CLI",
          "args_template": ["review", "{prompt}"]
        }
      ],
      "timeout_ms": 300000,
      "quorum_timeout_ms": 30000,
      "env": {}
    },
    {
      "name": "codex-2",
      "type": "subprocess",
      "description": "Execute Codex CLI agent non-interactively (slot 2)",
      "mainTool": "codex",
      "model": "gpt-5.3-codex",
      "model_detect": {
        "file": "~/.codex/config.toml",
        "pattern": "^model = \"([^\"]+)\""
      },
