      "display_provider": "AkashML",
      "cli": "ccr",
      "args_template": [
        "claude-1",
        "-p",
        "{prompt}",
        "--dangerously-skip-permissions"
      ],
      "health_check_args": [
        "-v"
      ],
      "helpArgs": [
        "--help"
      ],
      "extraTools": [],
      "timeout_ms": 300000,
